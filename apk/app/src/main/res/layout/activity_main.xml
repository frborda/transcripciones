<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grabador de reuniones"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="detenido"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1565C0" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:text=""
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnIniciar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#2E7D32"
            android:text="▶  INICIAR GRABACIÓN"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnCortar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#1565C0"
            android:text="✂  CORTAR Y ENVIAR (sigue grabando)"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnFinalizar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#C62828"
            android:text="⏹  FINALIZAR Y PROCESAR"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Partes de la sesión"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPartes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:text="(sin sesión todavía)"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Configuración"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Token del bot (BotFather)"
            android:inputType="text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etChat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="chat id"
                android:inputType="numberSigned" />

            <Button
                android:id="@+id/btnDetectar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detectar" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cbAuto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Envío automático cada" />

            <EditText
                android:id="@+id/etIntervalo"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:hint="hh:mm:ss"
                android:inputType="text"
                android:text="00:01:00" />
        </LinearLayout>

        <Button
            android:id="@+id/btnBateria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Permitir en segundo plano (batería)" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="El corte automático espera la primera PAUSA después del\nintervalo, para no cortar en medio de una frase.\nCon el teléfono bloqueado:\n• BAJAR VOLUMEN = cortar y enviar (vibra al cortar)\n• La notificación tiene botones ✂ Cortar y ⏹ Finalizar\nFINALIZAR pide confirmación, sube todo lo pendiente y\nmanda 'fin': la PC une todo, asigna hablantes sola y\nentrega los PDFs (después podés renombrarlos por chat)."
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
