<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingTop="20dp"
    android:paddingBottom="16dp"
    android:background="?attr/colorSurface">

    <!-- ===== Cabecera: ícono + título + engranaje de configuración ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_brand_circle"
            android:padding="10dp"
            android:src="@drawable/ic_mic"
            app:tint="@color/on_brand"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grabador de reuniones"
                android:textColor="?attr/colorOnSurface"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01" />

            <TextView
                android:id="@+id/tvSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reuniones → PDFs por Telegram"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnConfig"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_tune"
            app:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Configuración" />

        <ImageButton
            android:id="@+id/btnSalir"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Salir" />
    </LinearLayout>

    <!-- ===== Estado ===== -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:cardBackgroundColor="?attr/colorSurfaceContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <View
                android:id="@+id/dotEstado"
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:background="@drawable/status_dot" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="detenido"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text=""
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/pbNivel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:trackThickness="4dp"
                    app:trackCornerRadius="2dp"
                    android:max="100"
                    android:visibility="gone" />

                <!-- supresión de ruido en vivo + LED de voz (verde = detecta) -->
                <LinearLayout
                    android:id="@+id/filaSupresion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="supresión"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slSupresion"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="1"
                        app:labelBehavior="gone"
                        app:trackHeight="4dp"
                        app:thumbRadius="7dp" />

                    <TextView
                        android:id="@+id/tvCalidad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="monospace"
                        android:text=""
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/ledVoz"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/status_dot" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTest"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:minWidth="0dp"
                android:text="Probar"
                android:textAllCaps="false" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ===== Acciones ===== -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnIniciar"
        style="@style/Btn.Action"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/rec_green"
        android:text="Iniciar grabación"
        app:icon="@drawable/ic_mic" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCortar"
        style="@style/Btn.Action"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/cut_blue"
        android:text="Cortar y enviar"
        app:icon="@drawable/ic_cut" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFinalizar"
        style="@style/Btn.Action"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/fin_red"
        android:text="Finalizar y procesar"
        app:icon="@drawable/ic_stop" />

    <!-- gráfico en vivo de la detección de voz (30 s); alto y ancho se fijan en código -->
    <com.fer.grabador.GraficoVoz
        android:id="@+id/grafico"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="10dp"
        android:visibility="gone" />

    <!-- ===== Partes de la sesión (ocupa el resto; la lista scrollea ADENTRO) ===== -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_layers"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Partes de la sesión"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnEscuchar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_play"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="Escuchar partes" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/tvPartes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"
                    android:text="(sin sesión todavía)"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12.5sp" />
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Bloqueado: bajar volumen = cortar y enviar · Finalizar pide confirmación"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="11.5sp" />
</LinearLayout>
