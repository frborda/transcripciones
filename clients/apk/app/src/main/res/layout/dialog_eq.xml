<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <!-- estado: curva actual + claridad, o progreso del modo auto -->
        <TextView
            android:id="@+id/tvEqEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text=""
            android:textColor="?attr/colorOnSurface"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvEqG"
                android:layout_width="128dp"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="graves      +0.0"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slEqG"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:stepSize="0.5"
                android:valueFrom="-12"
                android:valueTo="12"
                app:labelBehavior="gone"
                app:thumbRadius="7dp"
                app:trackHeight="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvEqM"
                android:layout_width="128dp"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="medios      +0.0"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slEqM"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:stepSize="0.5"
                android:valueFrom="-12"
                android:valueTo="12"
                app:labelBehavior="gone"
                app:thumbRadius="7dp"
                app:trackHeight="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvEqP"
                android:layout_width="128dp"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="presencia   +0.0"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slEqP"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:stepSize="0.5"
                android:valueFrom="-12"
                android:valueTo="12"
                app:labelBehavior="gone"
                app:thumbRadius="7dp"
                app:trackHeight="4dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEqAuto"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="48dp"
            android:text="Ecualización automática"
            android:textAllCaps="false"
            app:icon="@drawable/ic_bolt"
            app:iconGravity="textStart" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="2dp"
            android:text="La automática prueba curvas mientras hablás (~1–2 min de habla continua, pareja): tu curva actual + 7 típicas, ajustes de ±3 dB alrededor de la ganadora, y una confirmación final contra plano — si no le gana claramente, queda plano. Mide la confianza del detector neuronal sobre tu voz. Al terminar la mejor queda FIJA hasta que la vuelvas a lanzar. Ideal: modo Probar con el celu en su posición real, hablando desde donde va a estar la gente."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
